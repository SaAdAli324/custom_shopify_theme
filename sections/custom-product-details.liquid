<div style="display: flex; flex-wrap: wrap; gap: 40px; padding: 40px; max-width: 1200px; margin: 0 auto;">
  <div style="flex: 1; min-width: 300px;">
    <img src="{{ product.featured_image | image_url: width: 600 }}" width="100%" height="auto"
      style=" border-radius: 8px;" alt="{{ product.title | escape }}">
  </div>

  <div style="flex: 1; min-width: 300px; display: flex; flex-direction: column; justify-content: center;">
    <h1 style="margin-top: 0; font-family: sans-serif;">{{ product.title }}</h1>
    <p style="font-size: 24px; color: #333; margin-bottom: 30px;">{{ product.price | money }}</p>
    {%if product.metafields.custom.material_type != blank%}
    <div>
      <strong>Material</strong>{{product.metafields.custom.material_type}}
    </div>
    {% endif %}
    {% form 'product', product , id:"add-to-cart-form" %}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" id="add-to-cart-button"
      style="padding: 15px 30px; background-color: var(--brand-primary); color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold; width: 100%; max-width: 300px;">
      Add to cart
    </button>
    {% endform %}
  </div>
</div>

<script>
  document.getElementById("add-to-cart-form").addEventListener("submit", async function (e) {
    e.preventDefault();
    let form = this;
    let submitButton = document.getElementById("add-to-cart-button");
    let originalText = submitButton.innerText;

    submitButton.innerText = "Adding to Cart...";
    submitButton.style.opacity = '0.7';

    let formData = new FormData(form);
    formData.append('sections', 'cart-icon-bubble');

    try {
      const response = await fetch('/cart/add.js', {
        method: "POST",
        body: formData
      });

      if (!response.ok) {
        throw new Error("Network response was not ok");
      }

      const parsedData = await response.json();
      console.log("Added to cart:", parsedData);

      // Update cart icon using the Section Rendering API response properly
      const cartIcon = document.getElementById('cart-icon-bubble');
      if (cartIcon && parsedData.sections && parsedData.sections['cart-icon-bubble']) {
        // Shopify wraps section responses in a div, so we must parse it to get the inner content
        const html = new DOMParser().parseFromString(parsedData.sections['cart-icon-bubble'], 'text/html');
        const newBubbleContent = html.querySelector('.shopify-section').innerHTML;

        cartIcon.innerHTML = newBubbleContent;
        console.log("Cart icon updated via DOMParser");

        // Ensure our custom style is applied to the newly rendered bubble if it doesn't have it
        const newCounter = cartIcon.querySelector('.cart-count-bubble span[aria-hidden="true"], #cart-counter');
        if (newCounter) {
          newCounter.id = 'cart-counter';
          newCounter.style.cssText = 'background-color: var(--brand-primary); color: white; border-radius: 50%; padding: 2px 6px; font-size: 12px; display: inline-block;';
        }
      }

      // Dispatch standard Dawn events to update cart drawer and other components automatically
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));

      submitButton.innerText = "Added successfully";
      submitButton.style.backgroundColor = "#4CAF50";
      submitButton.style.opacity = "1";

      setTimeout(() => {
        submitButton.innerText = originalText;
        submitButton.style.backgroundColor = 'var(--brand-primary)';
      }, 2000);

    } catch (error) {
      console.log("Error while adding to cart", error);
      submitButton.innerText = "Error-Try Again";
      submitButton.style.backgroundColor = "red";
      submitButton.style.opacity = "1";

      setTimeout(() => {
        submitButton.innerText = originalText;
        submitButton.style.backgroundColor = 'var(--brand-primary)';
      }, 2000);
    }
  });
</script>

{% schema %}
{
"name": "Custom Product Details",
"settings": [],
"presets": [
{
"name": "Custom Product Details"
}
]
}
{% endschema %}